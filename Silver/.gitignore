# Vault Sync - Security Rules
# Sync includes only markdown/state files
# Secrets never sync

# Configuration files that may contain credentials
*.env
.env
.env.local
.env.production
*.config.json
config.json

# Session files
whatsapp_session/
*session*

# Certificate and key files
*.pem
*.key
*.crt
*.cert

# Token and secret files
*token*
*secret*
*password*
*credential*

# System files
.DS_Store
Thumbs.db
*.tmp
*.temp

# Logs (for local only)
logs/
*.log

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.log

# Obsidian
.obsidian/
.vault/

# Other
node_modules/
.vscode/
.idea/
*.swp
*.swo
*~
